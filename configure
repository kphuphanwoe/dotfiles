#! /usr/bin/env bash
set -e

echo "Copying zshrc..."
cp .zshrc ~/.zshrc

echo "Copying bashrc..."
cp .bashrc ~/.bashrc

echo "Copying vimrc..."
cp .vimrc ~/.vimrc

echo "Copying tmux.conf..."
cp .tmux.conf ~/.tmux.conf

echo "Copying gitconfig..."
cp .gitconfig ~/.gitconfig

# mkdir -p ~/.opt/bin
# cp ./ack-v3.9.0-single-file ~/.opt/bin

echo "Done!! Take a break. Drink coffee."
